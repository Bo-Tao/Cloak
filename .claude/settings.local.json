{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:npm.100tal.com)",
      "WebFetch(domain:registry.npmmirror.com)",
      "WebFetch(domain:cdn.npmmirror.com)",
      "mcp__deepwiki__ask_question",
      "Bash(grep \"\"version\"\":*)",
      "Bash(kill %1:*)",
      "Bash(git tag:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  }
}
